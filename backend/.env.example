# ────────────────────────────
# AWS
# ────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name

# ────────────────────────────
# RDS (MySQL)
# ────────────────────────────
DB_HOST=your-rds-endpoint
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-db-password
DB_NAME=cloud_drive

# ────────────────────────────
# App
# ────────────────────────────
PORT=3000
